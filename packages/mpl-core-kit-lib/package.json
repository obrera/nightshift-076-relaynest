{
  "name": "@obrera/mpl-core-kit-lib",
  "version": "0.0.2",
  "description": "Temporary standalone extraction of the MPL Core @solana/kit helper library from beeman/mpl-core-kit",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obrera/mpl-core-kit-lib.git"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./generated": {
      "import": {
        "types": "./dist/generated.d.mts",
        "default": "./dist/generated.mjs"
      },
      "require": {
        "types": "./dist/generated.d.cts",
        "default": "./dist/generated.cjs"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/helpers.d.mts",
        "default": "./dist/helpers.mjs"
      },
      "require": {
        "types": "./dist/helpers.d.cts",
        "default": "./dist/helpers.cjs"
      }
    },
    "./hooked": {
      "import": {
        "types": "./dist/hooked.d.mts",
        "default": "./dist/hooked.mjs"
      },
      "require": {
        "types": "./dist/hooked.d.cts",
        "default": "./dist/hooked.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins.d.mts",
        "default": "./dist/plugins.mjs"
      },
      "require": {
        "types": "./dist/plugins.d.cts",
        "default": "./dist/plugins.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "check:package": "npm pack --dry-run",
    "changeset": "changeset",
    "check-types": "tsc -b --noEmit",
    "ci": "bun run build && bun run lint && bun run check-types && bun test",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "version": "changeset version && bun lint:fix"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1"
  },
  "peerDependencies": {
    "@solana/accounts": "^6.8.0",
    "@solana/addresses": "^6.8.0",
    "@solana/codecs": "^6.8.0",
    "@solana/kit": "^6.8.0",
    "@solana/rpc": "^6.8.0",
    "@solana/rpc-types": "^6.8.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "@solana/accounts": "^6.8.0",
    "@solana/addresses": "^6.8.0",
    "@solana/codecs": "^6.8.0",
    "@solana/kit": "^6.8.0",
    "@solana/rpc": "^6.8.0",
    "@solana/rpc-types": "^6.8.0",
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "^2.29.8",
    "@intellectronica/ruler": "^0.3.34",
    "@types/bun": "^1.3.9",
    "pkg-pr-new": "^0.0.62",
    "publint": "^0.3.16",
    "tsdown": "^0.20.3"
  }
}
