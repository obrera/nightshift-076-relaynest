{
  "name": "nightshift-076-relaynest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RelayNest build 076 - wallet-first neighborhood dispatch relay",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@obrera/mpl-core-kit-lib": "file:packages/mpl-core-kit-lib",
    "@solana/kit": "^6.8.0",
    "@wallet-ui/react": "^4.1.0",
    "better-sqlite3": "^12.5.0",
    "hono": "^4.10.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.2.1"
  },
  "overrides": {
    "@wallet-standard/ui-registry": "1.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
